{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/quote/[quoteId]",
      "regex": "^/quote/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPquoteId": "nxtPquoteId"
      },
      "namedRegex": "^/quote/(?<nxtPquoteId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/search/[searchtext]",
      "regex": "^/search/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPsearchtext": "nxtPsearchtext"
      },
      "namedRegex": "^/search/(?<nxtPsearchtext>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[username]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[username]/favoriters",
      "regex": "^/([^/]+?)/favoriters(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/(?<nxtPusername>[^/]+?)/favoriters(?:/)?$"
    },
    {
      "page": "/[username]/favoriting",
      "regex": "^/([^/]+?)/favoriting(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/(?<nxtPusername>[^/]+?)/favoriting(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/account/edit",
      "regex": "^/account/edit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/account/edit(?:/)?$"
    },
    {
      "page": "/changepassword",
      "regex": "^/changepassword(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/changepassword(?:/)?$"
    },
    {
      "page": "/explore",
      "regex": "^/explore(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/explore(?:/)?$"
    },
    {
      "page": "/forgotpassword",
      "regex": "^/forgotpassword(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/forgotpassword(?:/)?$"
    },
    {
      "page": "/notifications",
      "regex": "^/notifications(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/notifications(?:/)?$"
    },
    {
      "page": "/search",
      "regex": "^/search(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/search(?:/)?$"
    },
    {
      "page": "/signin",
      "regex": "^/signin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/signin(?:/)?$"
    },
    {
      "page": "/signup",
      "regex": "^/signup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/signup(?:/)?$"
    },
    {
      "page": "/terms",
      "regex": "^/terms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/terms(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}